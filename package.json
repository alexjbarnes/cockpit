{
  "name": "cockpit",
  "version": "0.1.0",
  "description": "Web UI for Claude Code",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexjbarnes/cockpit.git"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "web-ui"
  ],
  "bin": {
    "cockpit": "./bin/cockpit.js"
  },
  "files": [
    "dist/",
    ".next/",
    "!.next/cache/",
    "public/",
    "bin/",
    "package.json",
    "next.config.ts",
    "postcss.config.mjs"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "bun --watch --env-file=.env.development server.ts",
    "build": "bunx next build && tsc -p tsconfig.server.json",
    "start": "bun --env-file=.env.production dist/server.js",
    "lint": "biome check src/ tests/ server.ts",
    "lint:fix": "biome check --fix src/ tests/ server.ts",
    "format": "biome format --write src/ tests/ server.ts",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@pierre/diffs": "^1.0.11",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/postcss": "^4",
    "class-variance-authority": "^0.7",
    "clsx": "^2",
    "codemirror": "^6.0.2",
    "lucide-react": "^0.468",
    "magika": "^1.0.0",
    "next": "^15",
    "react": "^19",
    "react-dom": "^19",
    "react-markdown": "^9",
    "rehype-highlight": "^7",
    "remark-gfm": "^4",
    "shiki": "^4.0.2",
    "tailwind-merge": "^2",
    "tailwindcss": "^4",
    "uuid": "^11",
    "ws": "^8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10",
    "@types/ws": "^8",
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "5.9.3",
    "vitest": "^4.1.0"
  }
}
